# Normaliza fim de linha: no repositório sempre LF, no checkout o Git adapta.
# Garante consistência entre devs em Windows / Linux / macOS.
* text=auto eol=lf

# Arquivos que devem manter LF explicitamente
*.ts text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf
*.prisma text eol=lf
*.env text eol=lf

# Binários (nunca normalizar)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
