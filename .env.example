# ============================================
# 3F Core API - Environment Variables
# ============================================
# Copie este arquivo para .env e preencha com valores reais.
# NUNCA commite o arquivo .env no Git.

# ============================================
# Ambiente
# ============================================
# Valores aceitos: development | production | test
NODE_ENV=development

# ============================================
# Servidor HTTP
# ============================================
# Porta onde a API vai rodar localmente
PORT=3000

# Host de bind (0.0.0.0 aceita conexões externas, 127.0.0.1 só local)
HOST=0.0.0.0

# ============================================
# Banco de Dados (PostgreSQL)
# ============================================
# Connection string completa do Prisma
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/BANCO?schema=public
#
# Cenários:
# - Dev com Docker local:    postgresql://3f_core_app:senha@localhost:5432/3f_core?schema=public
# - Dev com túnel SSH:       postgresql://3f_core_app:senha@localhost:5433/3f_core?schema=public
# - Produção (VPS interna): postgresql://3f_core_app:senha@IP_VPS_BANCO:5432/3f_core?schema=public
DATABASE_URL=postgresql://3f_core_app:TROQUE_ESTA_SENHA@localhost:5432/3f_core?schema=public

# Pool de conexões (opcional, valores padrão funcionam pra maioria dos casos)
# DATABASE_CONNECTION_LIMIT=10
# DATABASE_POOL_TIMEOUT=10

# ============================================
# Logging
# ============================================
# Níveis: trace | debug | info | warn | error | fatal
# Recomendado: debug em dev, info em produção
LOG_LEVEL=debug

# Se true, formata logs bonitos no console (dev). Em produção, false (JSON estruturado).
LOG_PRETTY=true

# ============================================
# Segurança - bcrypt
# ============================================
# Cost factor do bcrypt (10-14). Quanto maior, mais seguro e mais lento.
# 12 é o equilíbrio recomendado em 2026.
BCRYPT_COST=12

# ============================================
# Rate Limiting
# ============================================
# Máximo de requests por janela de tempo, por API Key
RATE_LIMIT_MAX=100

# Janela de tempo em milissegundos (60000 = 1 minuto)
RATE_LIMIT_WINDOW_MS=60000

# ============================================
# API Keys
# ============================================
# Prefixo das API Keys geradas. Ajuda a identificar o ambiente da key.
# Exemplos: 3fc_live_ (produção), 3fc_test_ (homologação), 3fc_dev_ (dev)
API_KEY_PREFIX=3fc_dev_

# ============================================
# CORS (opcional, desabilitado por padrão)
# ============================================
# Se a API receber requests de browsers (SPAs), liste origens permitidas
# separadas por vírgula. Deixe vazio pra desabilitar CORS.
# Exemplo: https://app.3fventure.com.br,https://admin.3fventure.com.br
CORS_ORIGINS=

# ============================================
# Trust Proxy (importante em produção atrás de Nginx/Caddy)
# ============================================
# Em produção com proxy reverso, defina como true para o Express
# confiar nos headers X-Forwarded-* (ex: pra rate limit funcionar com IP real)
TRUST_PROXY=false